{% extends 'base.html.twig' %}

{% block title %}Listing Commande{% endblock %}

{% block content %}
    <section class="py-5">               
        <div class="container px-4 px-lg-5 my-5">
            {# Titre de la page #}
            <div class="row">
                <div class="col-lg-12">
                    <h1 class="page-header">Listing Commande</h1>
                </div>
            </div>

            <div class="row" role="alert">
                <div class="col-xs-9 col-sm-10"></div>

                <div class="col-xs-3 col-sm-2">
                    {% if (app.user and 'ROLE_ADMIN' in app.user.roles) or (app.user and 'ROLE_USE' in app.user.roles) %}
                    <a href="{{ path('app_commande_add') }}" role="button" class="btn btn-info text-right">
                        <i class="fa fa-plus fa-fw"></i> Ajouter
                    </a>
                    {% endif %}
                </div>
            </div>
        </div>
        <div class="container px-4 px-lg-5 my-5">
            <table class="table">
                <thead>
                    <tr>
                        {# sorting of properties based on query components #}
                        <th scope="col" {% if pagination.isSorted('commande.numerocommande') %} class="sorted"{% endif %}>
                            {{ knp_pagination_sortable(pagination, 'Num. comm.', 'commande.numerocommande') }}
                        </th>
                        <th scope="col" {% if pagination.isSorted('commande.datecommande') %} class="sorted"{% endif %}>
                            {{ knp_pagination_sortable(pagination, 'Date com.', 'commande.datecommande') }}
                        </th>
                        <th scope="col" {% if pagination.isSorted('commande.dateprestation') %} class="sorted"{% endif %}>
                            {{ knp_pagination_sortable(pagination, 'Date prest.', 'commande.dateprestation') }}
                        </th>
                        <th scope="col" {% if pagination.isSorted('commande.heurelivraison') %} class="sorted"{% endif %}>
                            {{ knp_pagination_sortable(pagination, 'Heure livr.', 'commande.heurelivraison') }}
                        </th>
                        <th scope="col" {% if pagination.isSorted('commande.prixmenu') %}} class="sorted"{% endif %}>
                            {{ knp_pagination_sortable(pagination, 'Prix menu', 'commande.prixmenu') }}
                        </th>
                    </tr>
                    <tr>
                        <th scope="col" {% if pagination.isSorted('commande.nombrepersonnes') %} class="sorted"{% endif %}>
                            {{ knp_pagination_sortable(pagination, 'Nb. pers.', 'commande.nombrepersonnes') }}
                        </th>
                        <th scope="col" {% if pagination.isSorted('commande.prixlivraison') %} class="sorted"{% endif %}>
                            {{ knp_pagination_sortable(pagination, 'Prix livr.', 'commande.prixlivraison') }}
                        </th>
                        <th scope="col" {% if pagination.isSorted('commande.statut') %} class="sorted"{% endif %}>
                            {{ knp_pagination_sortable(pagination, 'Statut', 'commande.statut') }}
                        </th>
                        <th scope="col" {% if pagination.isSorted('commande.pretmateriel') %} class="sorted"{% endif %}>
                            {{ knp_pagination_sortable(pagination, 'Pret mat.', 'commande.pretmateriel') }}
                        </th>   
                        <th scope="col" {% if pagination.isSorted('commande.restitutionmateriel') %} class="sorted"{% endif %}>
                            {{ knp_pagination_sortable(pagination, 'Rest. mat.', 'commande.restitutionmateriel') }}
                        </th>
                    </tr>
                </thead>               
                <tbody>
                    {% for commande in pagination %}
                    <tr>
                        <th colspan="3" scope="row">
                            <a href="{{ path('app_commande_index', {'id': commande.numerocommande}) }}" class="fw-bolder">{{ commande.numerocommande }}</a>
                            <p><strong>Date de la commande : </strong><br>{{ commande.datecommande|date('d/m/Y') }}</p>
                            <p><strong>Date de la prestation : </strong><br>{{ commande.dateprestation|date('d/m/Y') }}</p>
                            <p><strong>Menu : </strong><br>
                                {% if commande.menuId %}
                                    <a href="{{ path('app_menu_index', {'id': commande.menuId.menuid}) }}" class="fw-bolder">{{ commande.menuId.titre }}</a>
                                {% else %}
                                    Aucun menu associé
                                {% endif %}
                            </p>
                            <p><strong>Client : </strong><br>{{ commande.utilisateurId.prenom }} {{ commande.utilisateurId.nom }}</p>
                            <p><strong>Heure de livraison : </strong><br>{{ commande.heurelivraison }}</p>
                            <p><strong>Prix du Menu : </strong><br>{{ commande.prixmenu }} €</p>
                            <p><strong>Nombre de personnes : </strong><br>{{ commande.nombrepersonne }}</p>
                            <p><strong>Prix de livraison : </strong><br>{{ commande.prixlivraison }} €</p> 
                            <p><strong>Statut : </strong><br>{{ commande.statut }}</p>
                            <p><strong>Pret de matériel : </strong><br>{{ commande.pretmateriel ? 'Oui' : 'Non' }}</p>
                            <p><strong>Restitution de matériel : </strong><br>{{ commande.restitutionmateriel ? 'Oui' : 'Non' }}</p>
                        </th>
                        <td colspan="2" >
                            {% if (app.user and 'ROLE_ADMIN' in app.user.roles) or (app.user and 'ROLE_USE' in app.user.roles) %}
                            <a href="{{ path('app_commande_remove', {'id': commande.numerocommande}) }}" role="button" class="btn btn-danger">Supprimer</a>
                            <a href="{{ path('app_commande_edit', {'id': commande.numerocommande}) }}" role="button" class="btn btn-info">Modifier</a>
                            {% endif %}
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
            {# display navigation #}
            <div class="navigation">
                {{ knp_pagination_render(pagination) }}
            </div>            
        </div>
    </section>
{% endblock %}

{% block stylesheets %}
{% endblock %}
