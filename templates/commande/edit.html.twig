{% extends 'base.html.twig' %}

{% block title %}Commande{% endblock %}

{% block content %}
    <section class="py-5">
        <div class="container px-4 px-lg-5 my-5">
            {# Titre de la page #}
            <div class="row">
                <div class="col-lg-12">
                    <h1 class="page-header">{% if mode == 'new' %}Ajout{% else %}Modification{% endif %} - Commande</h1>
                </div>
            </div>
        </div>
        <div class="container px-4 px-lg-5 my-5">
            {{ form_start(form, {'method': 'POST', 'attr': {'novalidate': 'novalidate' }} ) }}

            {# ------------------------- #}
            {#      INFOS GÉNÉRALES      #}
            {# ------------------------- #}
            {% if mode == 'update' %}
            <div class="row" >
                <h4 class="col-lg-12">
                    <a data-group data-toggle="collapse" href="#info"><i class="fa fa-angle-double-down fa-fw"></i> Informations générales</a>
                </h4>
            </div>
            {% endif %}
        </div>
        <div class="container px-4 px-lg-5 my-5">
            <div id="info" class="panel-collapse">
                {% if (app.user and 'ROLE_ADMIN' in app.user.roles) or (app.user and 'ROLE_USE' in app.user.roles) %}
                <div class="input-field col s12 m6 l6 offset-m3 offset-l3">        
                {{ include('helpers/form/group.html.twig', {
                            'field': form['numerocommande'], 'attr': {'attr':{'size': '30'}}
                        }) }}
                </div>
                <div class="input-field col s12 m6 l6 offset-m3 offset-l3">        
                {{ include('helpers/form/group.html.twig', {
                            'field': form['datecommande'], 'attr': {'attr':{'size': '30', 'class': 'datePicker'}}
                        }) }}   
                </div>
                {% endif %}
                <div class="input-field col s12 m6 l6 offset-m3 offset-l    3">        
                {{ include('helpers/form/group.html.twig', {
                            'field': form['dateprestation'], 'attr': {'attr':{'size': '30', 'class': 'datePicker'}}
                        }) }}
                </div>
                {% if (app.user and 'ROLE_ADMIN' in app.user.roles) or (app.user and 'ROLE_USE' in app.user.roles) %}
                 <div class="input-field col s12 m6 l6 offset-m3 offset-l3">        
                {{ include('helpers/form/group.html.twig', {
                            'field': form['heurelivraison'], 'attr': {'attr':{'size': '30'}}
                        }) }}
                </div>
                <div class="input-field col s12 m6 l6 offset-m3 offset-l3">        
                {{ include('helpers/form/group.html.twig', {
                            'field': form['prixmenu'], 'attr': {'attr':{'size': '30'}}
                        }) }}   
                </div>
                {% endif %}
                <div class="input-field col s12 m6 l6 offset-m3 offset-l3">        
                {{ include('helpers/form/group.html.twig', {
                            'field': form['nombrepersonne'], 'attr': {'attr':{'size': '30'}}
                        }) }}
                </div>  
                {% if (app.user and 'ROLE_ADMIN' in app.user.roles) or (app.user and 'ROLE_USE' in app.user.roles) %}      
                <div class="input-field col s12 m6 l6 offset-m3 offset-l3">        
                {{ include('helpers/form/group.html.twig', {
                            'field': form['prixlivraison'], 'attr': {'attr':{'size': '30'}}
                        }) }}   
                </div>
                <div class="input-field col s12 m6 l6 offset-m3 offset-l3">        
                {{ include('helpers/form/group.html.twig', {
                            'field': form['statut'], 'attr': {'attr':{'rows': '8', 'cols': '30'}}
                        }) }}
                </div>
                {% endif %}
                <div class="input-field col s12 m6 l6 offset-m3 offset-l3">        
                {{ include('helpers/form/group.html.twig', {
                            'field': form['pretmateriel'], 'attr': {'attr':{}}
                        }) }}
                </div>
                {% if (app.user and 'ROLE_ADMIN' in app.user.roles) or (app.user and 'ROLE_USE' in app.user.roles) %}
                <div class="input-field col s12 m6 l6 offset-m3 offset-l3">        
                {{ include('helpers/form/group.html.twig', {
                            'field': form['restitutionmateriel'], 'attr': {'attr':{}}
                        }) }}
                </div>
                {% endif %}
            </div>
            <div class="row">
                {% if not form.vars.valid %}
                <div class="col-md-8 error">
                    <i class="fa fa-exclamation-triangle fa-fw">
                    Le formulaire contient des erreurs. Vérifiez les différentes rubriques.
                </div>
                {% else %}
                    <div class="col-md-8"></div>
                {% endif %} 
                <div class="col-md-8 text-right">
                    {{ form_widget(form.submit, { 'attr': {'class': 'btn btn-info'} }) }}
                </div>
            </div>
            {{ form_widget(form) }}
            {{ form_end(form) }}
        </div>
    </section>    

{% endblock %}

{% block stylesheets %}
{% endblock %}
