{% extends 'base.html.twig' %}

{% block title %}Listing aviss{% endblock %}

{% block content %}
    <section class="py-5">
        <div class="container px-4 px-lg-5 my-5">
            {# Titre de la page #}
            <div class="row">
                <div class="col-lg-12">
                    <h1 class="page-header">Listing Avis</h1>
                </div>
            </div>

            <div class="row" role="alert">
                <div class="col-xs-9 col-sm-10"></div>

                <div class="col-xs-3 col-sm-2">
                    {% if (app.user and 'ROLE_ADMIN' in app.user.roles) or (app.user and 'ROLE_USE' in app.user.roles) %}
                    <a href="{{ path('app_avis_add') }}" role="button" class="btn btn-info text-right">
                        <i class="fa fa-plus fa-fw"></i> Ajouter
                    </a>
                    {% endif %}
                </div>
            </div>
        </div>            
         <div class="container px-4 px-lg-5 my-5">
            <table class="table">
                <thead>
                    <tr>
                        <th scope="col" {% if pagination.isSorted('avis.note') %} class="sorted"{% endif %}>
                            {{ knp_pagination_sortable(pagination, 'Note', 'avis.note') }}
                        </th>
                        <th scope="col" {% if pagination.isSorted('avis.description') %} class="sorted"{% endif %}>
                            {{ knp_pagination_sortable(pagination, 'Description', 'avis.description') }}
                        </th>
                        <th scope="col" {% if pagination.isSorted('avis.statut') %} class="sorted"{% endif %}>
                            {{ knp_pagination_sortable(pagination, 'Statut', 'avis.statut') }}
                        </th>
                    </tr>
                </thead>
                <tbody>
                    {% for avis in pagination %}
                    <tr>
                        <th scope="row" colspan="2">
                            <a href="{{ path('app_avis_index', {'id': avis.avisid}) }}" class="fw-bolder">{{ avis.note|nl2br }}</a>
                            <p>Description : {{ avis.description|nl2br }}</p>
                            <p>Statut : {{ avis.statut }}</p>
                        </th>
                        <td>
                            {% if (app.user and 'ROLE_ADMIN' in app.user.roles) or (app.user and 'ROLE_USE' in app.user.roles) %}
                            <a href="{{ path('app_avis_remove', {'id': avis.avisid}) }}" role="button" class="btn btn-danger">Supprimer</a>
                            <a href="{{ path('app_avis_edit', {'id': avis.avisid}) }}" role="button" class="btn btn-info">Modifier</a>
                            {% endif %}
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
            {# display navigation #}
            <div class="navigation">
                {{ knp_pagination_render(pagination) }}
            </div>             
        </div>
    </section>
{% endblock %}

{% block stylesheets %}
{% endblock %}
